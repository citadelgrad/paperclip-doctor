{
  "name": "paperclip-doctor",
  "version": "0.1.0",
  "private": false,
  "description": "External Paperclip runtime healthcheck and doctor CLI",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/citadelgrad/paperclip-doctor.git"
  },
  "homepage": "https://github.com/citadelgrad/paperclip-doctor",
  "bugs": {
    "url": "https://github.com/citadelgrad/paperclip-doctor/issues"
  },
  "bin": {
    "paperclip-doctor": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "@types/node": "^24.6.0"
  }
}
